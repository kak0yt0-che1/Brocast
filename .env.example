# Скопируй в .env и впиши настоящие значения. .env в гит не коммить.

# --- Обязательное ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# --- Необязательное (показаны значения по умолчанию) ---
# true — матерная персона из phrases.json, false — вежливый режим
PHRASE_MODE_ENABLED=true

CITY_NAME=Almaty
LATITUDE=43.2389
LONGITUDE=76.8897
DEFAULT_TIMEZONE=Asia/Almaty

DATABASE_PATH=weatherbot.db
LOG_LEVEL=INFO
